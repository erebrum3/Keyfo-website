---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FAQ from '../components/FAQ.astro';
import Location from '../components/Location.astro';

import { BUSINESS } from '../data/business';
import { CONTENT_NL } from '../data/content.nl';

const SITE_ORIGIN = 'https://keyfo.nl';
const PAGE_PATH = '/kapsalon-schiedam/';
const PAGE_URL = `${SITE_ORIGIN}${PAGE_PATH}`;

const PAGE_TITLE = 'Kapsalon afhalen in Schiedam | KEYFO Broersveld';
const PAGE_DESCRIPTION =
  'Kapsalon afhalen bij KEYFO aan Broersveld 103 in Schiedam Centrum. Friet, döner, kaas en salade in één bakje. Bestelling doorgeven via WhatsApp of telefoon.';

const ogImageUrl = `${SITE_ORIGIN}/assets/keyfo/og-keyfo.jpg`;

const whatsappUrl = BUSINESS.getWhatsAppUrl('Hallo KEYFO, ik wil graag een kapsalon afhalen');
const hoursRange = `${BUSINESS.openingHours.opens}–${BUSINESS.openingHours.closes}`;
const hoursLineNl = `Elke dag behalve dinsdag ${hoursRange}`;

const FAQ_ITEMS = [
  {
    q: 'Wat zit er standaard in de kapsalon van KEYFO?',
    a: 'Onze kapsalon bestaat uit een laag verse friet, daarbovenop döner, gesmolten kaas en frisse salade. We serveren er saus naar keuze bij. Wilt u een variant zonder een van deze onderdelen? Geef het door bij uw bestelling.'
  },
  {
    q: 'Welke saus past goed bij een kapsalon?',
    a: 'De meeste gasten kiezen voor knoflooksaus of sambal — soms een combinatie van beide. Geef bij uw WhatsApp of telefoongesprek door welke saus u erbij wilt, dan voegen we die toe.'
  },
  {
    q: 'Hoe lang blijft een kapsalon goed nadat ik hem heb afgehaald?',
    a: 'Een kapsalon is op zijn lekkerst kort na het afhalen, zolang de friet nog krokant is en de kaas nog warm. We adviseren om de kapsalon binnen korte tijd op te eten en hem niet te lang in een afgesloten verpakking te laten staan.'
  }
] as const;

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  '@id': `${PAGE_URL}#breadcrumb`,
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: `${SITE_ORIGIN}/` },
    { '@type': 'ListItem', position: 2, name: 'Kapsalon Schiedam', item: PAGE_URL }
  ]
};

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${PAGE_URL}#webpage`,
  url: PAGE_URL,
  name: PAGE_TITLE,
  description: PAGE_DESCRIPTION,
  inLanguage: 'nl-NL',
  isPartOf: {
    '@type': 'WebSite',
    '@id': `${SITE_ORIGIN}/#website`,
    url: SITE_ORIGIN + '/',
    name: BUSINESS.canonicalName
  },
  breadcrumb: { '@id': `${PAGE_URL}#breadcrumb` }
};
---

<BaseLayout
  lang="nl"
  title={PAGE_TITLE}
  description={PAGE_DESCRIPTION}
  skipLinkLabel={CONTENT_NL.skipLinkLabel}
  canonicalUrl={PAGE_URL}
  alternateLanguages={[
    { hreflang: 'nl-NL', href: PAGE_URL },
    { hreflang: 'x-default', href: PAGE_URL }
  ]}
  openGraph={{
    type: 'website',
    locale: 'nl_NL',
    siteName: BUSINESS.canonicalName,
    image: ogImageUrl,
    imageAlt: 'KEYFO Restaurant & Cafe in Schiedam',
    imageType: 'image/jpeg',
    imageWidth: 1200,
    imageHeight: 630,
    imageSecureUrl: ogImageUrl
  }}
  jsonLd={[breadcrumbSchema, webPageSchema]}
  mobileCta={{
    ariaLabel: CONTENT_NL.mobileCtaAriaLabel,
    labels: CONTENT_NL.mobileCtaShort,
    hrefs: {
      menu: '/menu/',
      whatsapp: whatsappUrl,
      call: BUSINESS.phoneTel,
      route: BUSINESS.googleMapsDirectionsUrl
    }
  }}
>
  <Header
    brand={BUSINESS.canonicalName}
    langLabel="TR"
    langAriaLabel="Wissel naar Turks"
    langHref="/tr/"
    navAriaLabel={CONTENT_NL.navAriaLabel}
    nav={{
      menu: CONTENT_NL.nav.menu,
      popular: 'Populair',
      gallery: 'Galerij',
      location: CONTENT_NL.nav.locatie
    }}
    cta={{
      whatsapp: { label: 'Bestellen', href: whatsappUrl },
      phone: { label: 'Bellen', href: BUSINESS.phoneTel }
    }}
    linkPrefix="/"
  />

  <main id="main">
    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-container pt-28 sm:pt-32">
        <nav aria-label="Breadcrumb" class="keyfo-breadcrumb mb-4">
          <a href="/">Home</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">Kapsalon Schiedam</span>
        </nav>
        <p class="text-xs uppercase tracking-[0.2em] text-amber-300/80 mb-3">Schiedam Centrum · Broersveld 103</p>
        <h1 class="keyfo-brand text-4xl sm:text-5xl font-semibold text-white">
          Kapsalon afhalen in Schiedam
        </h1>
        <p class="keyfo-hero-intro mt-5 max-w-2xl">
          Trek in een stevige kapsalon om af te halen in Schiedam Centrum? Bij KEYFO aan Broersveld
          103 maken we de kapsalon ter plekke klaar — friet, döner, gesmolten kaas en salade in één
          bakje. Geef uw bestelling door via WhatsApp of telefoon en wij laten weten wanneer het
          klaarstaat.
        </p>
        <div class="mt-6 flex flex-wrap gap-3">
          <a class="keyfo-btn-primary" href={whatsappUrl} target="_blank" rel="noopener" data-event="click_whatsapp">
            Afhalen? Stuur ons een WhatsApp-bericht
          </a>
          <a class="keyfo-btn-secondary" href={BUSINESS.phoneTel} data-event="click_phone">Bel KEYFO</a>
          <a
            class="keyfo-btn-secondary"
            href={BUSINESS.googleMapsDirectionsUrl}
            target="_blank"
            rel="noopener"
            data-event="click_route"
          >
            Route bekijken
          </a>
        </div>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container max-w-3xl space-y-4 leading-relaxed text-zinc-800">
        <h2 class="keyfo-section-title">Wat zit er in onze kapsalon?</h2>
        <p>
          Een kapsalon is in de basis een bakje met een laag friet, daarbovenop döner, gesmolten
          kaas en frisse salade. Wij bouwen de onze in dezelfde volgorde, zodat de friet onderin
          warm blijft terwijl de salade bovenop fris blijft. Saus serveren we apart of erbij — naar
          uw voorkeur.
        </p>
        <p>
          Heeft u liever alleen de döner zonder de friet en kaas eromheen? Bekijk dan onze pagina
          over <a class="underline" href="/doner-schiedam/">döner afhalen in Schiedam</a>. Of
          neem een kijkje op de
          <a class="underline" href="/menu/" data-event="click_menu">volledige menukaart</a> voor
          het actuele aanbod.
        </p>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container max-w-3xl space-y-4 leading-relaxed text-zinc-800">
        <h2 class="keyfo-section-title">Kapsalon afhalen in Schiedam Centrum</h2>
        <p>
          KEYFO ligt midden in Schiedam Centrum, op loopafstand van station Schiedam Centrum en de
          Nieuwe Passage. Komt u tussendoor langs voor een kapsalon? Wij raden aan om kort van
          tevoren contact op te nemen, zodat we de bestelling voor uw aankomst kunnen klaarmaken
          en u niet hoeft te wachten.
        </p>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-container max-w-3xl space-y-4 leading-relaxed text-zinc-200">
        <h2 class="keyfo-section-title text-white">Afhalen via WhatsApp</h2>
        <p>
          Het prettigste is om uw bestelling kort door te geven via WhatsApp. U vertelt hoeveel
          kapsalons u wilt, welke saus en eventuele aanpassingen — bijvoorbeeld zonder ui of met
          extra salade. Wij bevestigen wat het kost en wanneer u kunt langskomen. Bellen kan
          natuurlijk ook.
        </p>
        <p>
          We werken niet met een online betaalsysteem; u rekent ter plaatse af bij het ophalen. Zo
          blijft het contact direct en kunnen we makkelijk meedenken met uw voorkeuren.
        </p>
        <div class="mt-2 flex flex-wrap gap-3">
          <a class="keyfo-btn-primary" href={whatsappUrl} target="_blank" rel="noopener" data-event="click_whatsapp">
            WhatsApp ons
          </a>
          <a class="keyfo-btn-secondary" href={BUSINESS.phoneTel} data-event="click_phone">Bel KEYFO</a>
        </div>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-container">
        <Location
          heading="Locatie en parkeren"
          eyebrow="Vinden en ophalen"
          intro="Adres en route naar KEYFO aan Broersveld 103 in Schiedam Centrum."
          addressLines={[
            `${BUSINESS.canonicalName}`,
            `${BUSINESS.address.streetAddress}`,
            `${BUSINESS.address.postalCode} ${BUSINESS.address.addressLocality}`
          ]}
          hoursLine={hoursLineNl}
          parkingLine="Parkeermogelijkheden kunnen per moment verschillen; controleer vooraf de actuele parkeerinfo."
          links={[
            { label: 'Afhalen? Stuur ons een WhatsApp-bericht', href: whatsappUrl, isExternal: true, variant: 'primary' },
            { label: 'Bel KEYFO', href: BUSINESS.phoneTel, variant: 'secondary' },
            { label: 'Route bekijken', href: BUSINESS.googleMapsDirectionsUrl, isExternal: true, variant: 'secondary' },
            { label: 'Bekijk volledige menukaart', href: '/menu/', variant: 'tertiary' }
          ]}
          mapEmbedUrl={BUSINESS.googleMapsEmbedUrl}
          mapDirectionsUrl={BUSINESS.googleMapsDirectionsUrl}
          mapCtaLabel="Route openen in Google Maps"
        />
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container">
        <FAQ heading="Veelgestelde vragen over kapsalon" items={FAQ_ITEMS} />
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container max-w-3xl space-y-4 leading-relaxed text-zinc-800">
        <h2 class="keyfo-section-title">Klaar voor uw kapsalon?</h2>
        <p>
          Stuur een WhatsApp of bel ons even — dan staat de kapsalon klaar wanneer u langskomt.
          Liever eerst rondkijken? Bekijk de
          <a class="underline" href="/menu/" data-event="click_menu">volledige menukaart</a> of de
          pagina <a class="underline" href="/doner-schiedam/">döner afhalen in Schiedam</a>.
        </p>
        <div class="mt-2 flex flex-wrap gap-3">
          <a class="keyfo-btn-primary" href={whatsappUrl} target="_blank" rel="noopener" data-event="click_whatsapp">
            Afhalen? Stuur ons een WhatsApp-bericht
          </a>
          <a class="keyfo-btn-secondary" href={BUSINESS.phoneTel} data-event="click_phone">Bel KEYFO</a>
          <a class="keyfo-btn-secondary" href={BUSINESS.googleMapsDirectionsUrl} target="_blank" rel="noopener" data-event="click_route">
            Route bekijken
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer
    brand={BUSINESS.canonicalName}
    tagline={CONTENT_NL.heroSubheading}
    napLines={[
      `Adres: ${BUSINESS.address.streetAddress}, ${BUSINESS.address.postalCode} ${BUSINESS.address.addressLocality}`,
      `Telefoon/WhatsApp: ${BUSINESS.phone}`,
      `E-mail: ${BUSINESS.email}`
    ]}
    columns={[
      {
        label: 'Acties',
        links: [
          { label: 'Afhalen? Stuur ons een WhatsApp-bericht', href: whatsappUrl, isExternal: true },
          { label: 'Bel KEYFO', href: BUSINESS.phoneTel },
          { label: 'Route bekijken', href: BUSINESS.googleMapsDirectionsUrl, isExternal: true },
          { label: 'Bekijk volledige menukaart', href: '/menu/' }
        ]
      },
      {
        label: 'Sociaal',
        links: [
          { label: 'Instagram', href: BUSINESS.social.instagram, isExternal: true },
          { label: 'Facebook', href: BUSINESS.social.facebook, isExternal: true },
          { label: 'TikTok', href: BUSINESS.social.tiktok, isExternal: true },
          { label: 'X', href: BUSINESS.social.twitter, isExternal: true },
          { label: 'Pinterest', href: BUSINESS.social.pinterest, isExternal: true }
        ]
      },
      {
        label: 'Lokaal',
        links: [
          { label: 'Turks restaurant Schiedam', href: '/turks-restaurant-schiedam/' },
          { label: 'Döner Schiedam', href: '/doner-schiedam/' },
          { label: 'Turkse pizza Schiedam', href: '/turkse-pizza-schiedam/' }
        ]
      }
    ]}
    legalLine={`© ${new Date().getFullYear()} ${BUSINESS.canonicalName}`}
  />
</BaseLayout>
