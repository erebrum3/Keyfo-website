---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Hero from '../../components/Hero.astro';
import HeroQuickAccess from '../../components/HeroQuickAccess.astro';
import InfoBar from '../../components/InfoBar.astro';
import PopularDishes from '../../components/PopularDishes.astro';
import MenuTeaser from '../../components/MenuTeaser.astro';
import Gallery from '../../components/Gallery.astro';
import Reviews from '../../components/Reviews.astro';
import Location from '../../components/Location.astro';
import FAQ from '../../components/FAQ.astro';
import Footer from '../../components/Footer.astro';

import { BUSINESS } from '../../data/business';
import { MENU, formatPriceEurNl, type MenuItem } from '../../data/menu';
import { CONTENT_TR } from '../../data/content.tr';
import { REVIEWS } from '../../data/reviews';

const featured = MENU.categories
  .flatMap((c) => (c.items as MenuItem[]).filter((i) => i.featured).map((i) => ({ ...i, categoryTitle: c.titleTr })))
  .slice(0, 4)
  .map((i) => ({ ...i, priceLabel: formatPriceEurNl(i.priceEur), description: i.descriptionTr }));

const hoursRange = `${BUSINESS.openingHours.opens}–${BUSINESS.openingHours.closes}`;
const hoursLineTr = `Salı hariç her gün ${hoursRange}`;

const SITE_ORIGIN = 'https://keyfo.nl';
const ogImageUrl = `${SITE_ORIGIN}/assets/keyfo/og-keyfo.jpg`;

const restaurantSchema = {
  '@context': 'https://schema.org',
  '@type': 'Restaurant',
  '@id': `${SITE_ORIGIN}/#restaurant`,
  name: BUSINESS.canonicalName,
  url: BUSINESS.website.trUrl,
  image: [
    `${SITE_ORIGIN}/assets/keyfo/hero-interior.jpg`,
    `${SITE_ORIGIN}/assets/keyfo/sign.jpg`,
    `${SITE_ORIGIN}/assets/keyfo/interior-wide.jpg`
  ],
  telephone: BUSINESS.phone,
  email: BUSINESS.email,
  address: {
    '@type': 'PostalAddress',
    streetAddress: BUSINESS.address.streetAddress,
    postalCode: BUSINESS.address.postalCode,
    addressLocality: BUSINESS.address.addressLocality,
    addressCountry: BUSINESS.address.addressCountry
  },
  openingHoursSpecification: {
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: [...BUSINESS.openingHours.days],
    opens: BUSINESS.openingHours.opens,
    closes: BUSINESS.openingHours.closes
  },
  servesCuisine: BUSINESS.servesCuisine,
  areaServed: {
    '@type': BUSINESS.areaServed.type,
    name: BUSINESS.areaServed.name
  },
  currenciesAccepted: BUSINESS.currency,
  hasMenu: {
    '@type': 'Menu',
    '@id': `${SITE_ORIGIN}/#menu`,
    name: 'KEYFO menü',
    url: `${SITE_ORIGIN}/tr/menu/`,
    inLanguage: ['tr', 'nl']
  },
  hasMap: BUSINESS.googleMapsDirectionsUrl,
  sameAs: [
    BUSINESS.social.instagram,
    BUSINESS.social.facebook,
    BUSINESS.social.tiktok,
    BUSINESS.social.twitter,
    BUSINESS.social.pinterest,
    BUSINESS.social.thuisbezorgd
  ],
  paymentAccepted: BUSINESS.paymentAccepted
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: CONTENT_TR.faq.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: {
      '@type': 'Answer',
      text: it.a
    }
  }))
};
---

<BaseLayout
  lang="tr"
  title={CONTENT_TR.pageTitle}
  description={CONTENT_TR.pageDescription}
  skipLinkLabel={CONTENT_TR.skipLinkLabel}
  canonicalUrl={BUSINESS.website.trUrl}
  alternateLanguages={[
    { hreflang: 'nl-NL', href: BUSINESS.website.nlUrl },
    { hreflang: 'tr-TR', href: BUSINESS.website.trUrl },
    { hreflang: 'x-default', href: BUSINESS.website.nlUrl }
  ]}
  openGraph={{
    type: 'website',
    locale: 'tr_TR',
    siteName: BUSINESS.canonicalName,
    image: ogImageUrl,
    imageAlt: 'KEYFO Restaurant & Cafe Schiedam',
    imageType: 'image/jpeg',
    imageWidth: 1200,
    imageHeight: 630,
    imageSecureUrl: ogImageUrl
  }}
  jsonLd={[restaurantSchema, faqSchema]}
  mobileCta={{
    ariaLabel: CONTENT_TR.mobileCtaAriaLabel,
    labels: CONTENT_TR.mobileCtaShort,
    hrefs: {
      menu: '#menu',
      whatsapp: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill),
      call: BUSINESS.phoneTel,
      route: BUSINESS.googleMapsDirectionsUrl
    }
  }}
>
  <Header
    brand={BUSINESS.canonicalName}
    langLabel="NL"
    langAriaLabel="Hollandacaya geç"
    langHref="/"
    navAriaLabel={CONTENT_TR.navAriaLabel}
    nav={{
      menu: CONTENT_TR.nav.menu,
      popular: 'Popüler',
      gallery: 'Galeri',
      location: CONTENT_TR.nav.konum
    }}
    reserveLink={{ label: 'Rezervasyon', href: '/tr/rezervasyon/' }}
    cta={{
      whatsapp: { label: 'Gel-Al', href: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill) },
      phone: { label: 'Ara', href: BUSINESS.phoneTel }
    }}
  />

  <main id="main">
    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-hero-container">
        <Hero
          heading={BUSINESS.canonicalName}
          subheading={CONTENT_TR.heroSubheading}
          kicker={CONTENT_TR.heroKicker}
          ops={CONTENT_TR.heroOps}
          rating={{
            value: BUSINESS.googleRating,
            count: BUSINESS.googleReviewCount,
            label: CONTENT_TR.heroRatingLabel,
            ariaLabel: CONTENT_TR.heroRatingAriaLabel,
            url: BUSINESS.googleReviewsUrl
          }}
          ctas={{
            viewMenu: { label: CONTENT_TR.ctas.viewMenu, href: '#menu' },
            whatsapp: { label: CONTENT_TR.ctas.whatsappPickup, href: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill) },
            phone: { label: CONTENT_TR.ctas.callNow, href: BUSINESS.phoneTel },
            route: { label: CONTENT_TR.ctas.viewRoute, href: BUSINESS.googleMapsDirectionsUrl },
            delivery: { label: CONTENT_TR.ctas.thuisbezorgd, href: BUSINESS.social.thuisbezorgd }
          }}
        />
        <div class="keyfo-hero-foot">
          <p class="keyfo-hero-intro">{CONTENT_TR.heroIntro}</p>
          <p class="keyfo-hero-intro">
            <a class="underline" href="/tr/turks-restoran-schiedam/">Schiedam Merkez'de Türk restoranı</a> hakkında daha fazla bilgi mi istiyorsunuz?
          </p>
          <aside class="keyfo-dev-notice" aria-label="Bilgilendirme">
            <span class="keyfo-dev-notice__label">Bilgilendirme</span>
            <p class="keyfo-dev-notice__body">
              Bu web sitesi Erebrum AI Agency tarafından geliştirilmiştir. Teknik altyapı, görsel tasarım ve marka kimliği sürekli olarak iyileştirilmektedir. İletişim ve iş birliği için: <a href="mailto:info@erebrum.com">info@erebrum.com</a>.
            </p>
          </aside>
        </div>
      </div>
    </section>

    <HeroQuickAccess locale="tr" />

    <InfoBar
      ariaLabel="Temel bilgiler"
      items={[
        { icon: 'user', label: 'Kadın işletmeci', accent: 'amber' },
        { icon: 'sparkle', label: 'Temiz & özenli', accent: 'amber' },
        { icon: 'car', label: 'Garage Nieuwe Passage · 3 dk yürüyüş', accent: 'amber' },
        { icon: 'check', label: CONTENT_TR.halalWording, accent: 'green' }
      ]}
    />

    <div class="keyfo-kilim-band">
      <section id="populair" class="keyfo-section keyfo-band-cream">
        <div class="keyfo-container">
          <PopularDishes
            heading={CONTENT_TR.featuredHeading}
            eyebrow={CONTENT_TR.featuredEyebrow}
            lead={CONTENT_TR.featuredLead}
            ctaLabel={CONTENT_TR.ctas.viewMenu}
            ctaHref="#menu"
            items={featured}
          />
        </div>
      </section>

      <section id="menu" class="keyfo-section keyfo-band-cream">
        <div class="keyfo-container">
          <MenuTeaser
            heading={CONTENT_TR.menuPage.teaserHeading}
            eyebrow={CONTENT_TR.menuPage.teaserEyebrow}
            lead={CONTENT_TR.menuPage.teaserLead}
            categories={MENU.categories.map((c) => ({ ...c, title: c.titleTr }))}
            formatPrice={formatPriceEurNl}
            itemCountLabel={CONTENT_TR.menuPage.teaserItemCountLabel}
            priceRangeLabel={CONTENT_TR.menuPage.teaserPriceRangeLabel}
            ctaLabel={CONTENT_TR.menuPage.teaserCtaLabel}
            ctaHref="/tr/menu/"
          />
        </div>
      </section>
    </div>

    <section class="keyfo-section keyfo-band-dark keyfo-band-dark--leather">
      <div class="keyfo-container">
        <Reviews
          eyebrow="Misafir yorumları"
          heading="KEYFO’yu ziyaret eden misafirlerin gerçek Google yorumları."
          intro="Schiedam’daki Keyfo hakkında son Google yorumlarından bir akış."
          ratingValue={BUSINESS.googleRating}
          reviewCount={BUSINESS.googleReviewCount}
          reviewCountLabel="Google yorumu"
          ratingSummaryNote="Google yorumlarına dayanmaktadır"
          ratingAriaLabel="Puan"
          reviews={REVIEWS}
          lang="tr"
          prevLabel="Önceki yorum"
          nextLabel="Sonraki yorum"
          cta={{ label: 'Tüm Google yorumlarını gör', href: BUSINESS.googleReviewsUrl }}
        />
      </div>
    </section>

    <section id="gallery" class="keyfo-section keyfo-band-plaster">
      <div class="keyfo-container">
        <Gallery heading={CONTENT_TR.galleryHeading} eyebrow={CONTENT_TR.galleryEyebrow} introText={CONTENT_TR.galleryIntro} items={CONTENT_TR.galleryItems} />
      </div>
    </section>

    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-container">
        <Location
          heading={CONTENT_TR.locationHeading}
          eyebrow={CONTENT_TR.locationEyebrow}
          intro={CONTENT_TR.locationIntro}
          addressLabel="Adres"
          contactLabel="İşlemler"
          addressLines={[
            `${BUSINESS.canonicalName}`,
            `${BUSINESS.address.streetAddress}`,
            `${BUSINESS.address.postalCode} ${BUSINESS.address.addressLocality}`
          ]}
          hoursLine={hoursLineTr}
          parkingLine="Garage Nieuwe Passage, Koemarkt girişi · yaklaşık 3 dk yürüyüş · güncel park koşullarını kontrol edin"
          links={[
            { label: CONTENT_TR.ctas.whatsappPickup, href: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill), isExternal: true, variant: 'primary' },
            { label: CONTENT_TR.ctas.callNow, href: BUSINESS.phoneTel, variant: 'secondary' },
            { label: 'E-posta', href: BUSINESS.emailMailto },
            { label: CONTENT_TR.ctas.viewRoute, href: BUSINESS.googleMapsDirectionsUrl, isExternal: true, variant: 'secondary' },
            { label: CONTENT_TR.ctas.thuisbezorgd, href: BUSINESS.social.thuisbezorgd, isExternal: true, variant: 'tertiary' }
          ]}
          mapEmbedUrl={BUSINESS.googleMapsEmbedUrl}
          mapDirectionsUrl={BUSINESS.googleMapsDirectionsUrl}
          mapCtaLabel="Yol tarifini Google Maps'te aç"
        />
        <p class="mt-6 text-center text-zinc-300">
          <a class="underline" href="/tr/turks-restoran-schiedam/">Schiedam Merkez'de Türk yemekleri</a> sayfamıza da göz atın.
        </p>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container">
        <FAQ heading={CONTENT_TR.faqHeading} items={CONTENT_TR.faq} />
      </div>
    </section>
  </main>

  <Footer
    brand={BUSINESS.canonicalName}
    tagline={CONTENT_TR.heroSubheading}
    napLines={[
      `Adres: ${BUSINESS.address.streetAddress}, ${BUSINESS.address.postalCode} ${BUSINESS.address.addressLocality}`,
      `Telefon/WhatsApp: ${BUSINESS.phone}`,
      `E-posta: ${BUSINESS.email}`
    ]}
    columns={[
      {
        label: 'İşlemler',
        links: [
          { label: CONTENT_TR.ctas.whatsappPickup, href: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill), isExternal: true },
          { label: CONTENT_TR.ctas.callNow, href: BUSINESS.phoneTel },
          { label: CONTENT_TR.ctas.viewRoute, href: BUSINESS.googleMapsDirectionsUrl, isExternal: true },
          { label: CONTENT_TR.ctas.thuisbezorgd, href: BUSINESS.social.thuisbezorgd, isExternal: true }
        ]
      },
      {
        label: 'Sosyal',
        links: [
          { label: 'Instagram', href: BUSINESS.social.instagram, isExternal: true },
          { label: 'Facebook', href: BUSINESS.social.facebook, isExternal: true },
          { label: 'TikTok', href: BUSINESS.social.tiktok, isExternal: true },
          { label: 'X', href: BUSINESS.social.twitter, isExternal: true },
          { label: 'Pinterest', href: BUSINESS.social.pinterest, isExternal: true }
        ]
      },
      {
        label: 'Yerel',
        links: [
          { label: "Schiedam'da Türk restoranı", href: '/tr/turks-restoran-schiedam/' }
        ]
      }
    ]}
    legalLine={`© ${new Date().getFullYear()} ${BUSINESS.canonicalName}`}
  />
</BaseLayout>
