---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ReservationForm from '../../components/ReservationForm.astro';
import FAQ from '../../components/FAQ.astro';

import { BUSINESS } from '../../data/business';
import { CONTENT_TR } from '../../data/content.tr';

const SITE_ORIGIN = 'https://keyfo.nl';
const CANONICAL = `${SITE_ORIGIN}/tr/rezervasyon/`;
const NL_URL = `${SITE_ORIGIN}/reserveren/`;
const ogImageUrl = `${SITE_ORIGIN}/assets/keyfo/og-keyfo.jpg`;

const c = CONTENT_TR.reservation;

const FAQ_ITEMS = [
  {
    q: 'Rezervasyon otomatik olarak onaylanır mı?',
    a: 'Hayır. KEYFO\'da rezervasyonlar otomatik olarak onaylanmaz. Talebinizi inceleyip istediğiniz tarih ve saatin uygun olup olmadığını WhatsApp üzerinden onaylarız.'
  },
  {
    q: 'Aynı gün için talep gönderebilir miyim?',
    a: 'Evet. Bugün veya yarın için de talep gönderebilirsiniz. Yoğunluğa bağlı olarak yanıt süresi değişebilir; kısa süreli talepler için ayrıca telefonla aramanızı da öneririz.'
  },
  {
    q: 'Kalabalık grup için nasıl bilgi vermeliyim?',
    a: 'Kalabalık gruplar için bunu talebinizde belirtmeniz veya /tr/toplu-gel-al-schiedam/ üzerinden toplu talep göndermeniz işimizi kolaylaştırır. Böylece yeterli alan ve zaman ayırabiliriz.'
  }
] as const;

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${CANONICAL}#webpage`,
  url: CANONICAL,
  name: c.pageTitle,
  description: c.pageDescription,
  inLanguage: 'tr',
  isPartOf: { '@id': `${SITE_ORIGIN}/#website` }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: c.breadcrumbHome, item: BUSINESS.website.trUrl },
    { '@type': 'ListItem', position: 2, name: c.breadcrumbCurrent, item: CANONICAL }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a }
  }))
};
---

<BaseLayout
  lang="tr"
  title={c.pageTitle}
  description={c.pageDescription}
  skipLinkLabel={CONTENT_TR.skipLinkLabel}
  canonicalUrl={CANONICAL}
  alternateLanguages={[
    { hreflang: 'tr-TR', href: CANONICAL },
    { hreflang: 'nl-NL', href: NL_URL },
    { hreflang: 'x-default', href: NL_URL }
  ]}
  openGraph={{
    type: 'website',
    locale: 'tr_TR',
    siteName: BUSINESS.canonicalName,
    image: ogImageUrl,
    imageAlt: 'KEYFO Restaurant & Cafe Schiedam',
    imageType: 'image/jpeg',
    imageWidth: 1200,
    imageHeight: 630,
    imageSecureUrl: ogImageUrl
  }}
  jsonLd={[webPageSchema, breadcrumbSchema, faqSchema]}
  mobileCta={{
    ariaLabel: CONTENT_TR.mobileCtaAriaLabel,
    labels: CONTENT_TR.mobileCtaShort,
    hrefs: {
      menu: '/tr/menu/',
      whatsapp: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill),
      call: BUSINESS.phoneTel,
      route: BUSINESS.googleMapsDirectionsUrl
    }
  }}
>
  <Header
    brand={BUSINESS.canonicalName}
    langLabel="NL"
    langAriaLabel="Hollandacaya geç"
    langHref={NL_URL}
    navAriaLabel={CONTENT_TR.navAriaLabel}
    nav={{
      menu: CONTENT_TR.nav.menu,
      popular: 'Popüler',
      gallery: 'Galeri',
      location: CONTENT_TR.nav.konum
    }}
    cta={{
      whatsapp: { label: 'Gel-Al', href: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill) },
      phone: { label: 'Ara', href: BUSINESS.phoneTel }
    }}
  />

  <main id="main">
    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-container">
        <nav aria-label="Breadcrumb" class="keyfo-breadcrumb">
          <a href="/tr/">{c.breadcrumbHome}</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{c.breadcrumbCurrent}</span>
        </nav>
        <header class="keyfo-menu-page-head">
          <span class="keyfo-menu-eyebrow">{c.eyebrow}</span>
          <h1 class="keyfo-menu-page-title keyfo-brand">{c.heading}</h1>
          <p class="keyfo-menu-page-lead">{c.lead}</p>
        </header>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container keyfo-req-container">
        <ReservationForm locale="tr" sourcePage="tr/rezervasyon" />
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container max-w-3xl space-y-8 leading-relaxed text-zinc-800">
        <div class="space-y-3">
          <h2 class="keyfo-section-title">KEYFO'da rezervasyon nasıl çalışır?</h2>
          <ol class="list-decimal pl-6 space-y-2">
            <li>Yukarıdaki form veya WhatsApp üzerinden talebinizi gönderin.</li>
            <li>Tarih, saat, kişi sayısı ve varsa notlarınızı belirtin.</li>
            <li>KEYFO talebi inceler.</li>
            <li>Rezervasyonunuz, KEYFO WhatsApp üzerinden onayladıktan sonra kesinleşir.</li>
          </ol>
        </div>
        <div class="space-y-3">
          <h2 class="keyfo-section-title">Kalabalık gruplar için bilgi</h2>
          <p>
            Aile, ofis veya bir kutlama için kalabalık bir grupla mı geleceksiniz? Bu durumda
            <a class="underline" href="/tr/toplu-gel-al-schiedam/">toplu gel-al talebi</a>
            genellikle daha uygundur. Orada ürün, kişi sayısı ve gelecek detayları önceden
            belirtebilirsiniz; biz de buna göre planlama yaparız. Standart masa rezervasyonu
            elbette yukarıdaki form üzerinden de mümkündür.
          </p>
        </div>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container">
        <FAQ heading="Rezervasyon hakkında sıkça sorulan sorular" items={FAQ_ITEMS} />
      </div>
    </section>
  </main>

  <Footer
    brand={BUSINESS.canonicalName}
    tagline={CONTENT_TR.heroSubheading}
    napLines={[
      `Adres: ${BUSINESS.address.streetAddress}, ${BUSINESS.address.postalCode} ${BUSINESS.address.addressLocality}`,
      `Telefon/WhatsApp: ${BUSINESS.phone}`,
      `E-posta: ${BUSINESS.email}`
    ]}
    columns={[
      {
        label: 'İşlemler',
        links: [
          { label: CONTENT_TR.ctas.whatsappPickup, href: BUSINESS.getWhatsAppUrl(CONTENT_TR.whatsappPrefill), isExternal: true },
          { label: CONTENT_TR.ctas.callNow, href: BUSINESS.phoneTel },
          { label: CONTENT_TR.ctas.viewRoute, href: BUSINESS.googleMapsDirectionsUrl, isExternal: true }
        ]
      },
      {
        label: 'Yerel',
        links: [
          { label: 'Schiedam Türk restoranı', href: '/tr/turks-restoran-schiedam/' },
          { label: 'Rezervasyon', href: '/tr/rezervasyon/' },
          { label: 'Toplu gel-al', href: '/tr/toplu-gel-al-schiedam/' }
        ]
      }
    ]}
    legalLine={`© ${new Date().getFullYear()} ${BUSINESS.canonicalName}`}
  />
</BaseLayout>
