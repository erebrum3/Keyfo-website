---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CateringForm from '../components/CateringForm.astro';
import FAQ from '../components/FAQ.astro';

import { BUSINESS } from '../data/business';
import { CONTENT_NL } from '../data/content.nl';

const SITE_ORIGIN = 'https://keyfo.nl';
const CANONICAL = `${SITE_ORIGIN}/groepsbestelling-schiedam/`;
const TR_URL = `${SITE_ORIGIN}/tr/toplu-gel-al-schiedam/`;
const ogImageUrl = `${SITE_ORIGIN}/assets/keyfo/og-keyfo.jpg`;

const c = CONTENT_NL.groepsbestelling;

const FAQ_ITEMS = [
  {
    q: 'Krijg ik direct een bevestiging van mijn groepsaanvraag?',
    a: 'Nee. Groepsaanvragen worden door ons handmatig bekeken — geen geautomatiseerd systeem. Uw aanvraag is pas definitief nadat KEYFO via WhatsApp heeft bevestigd dat de gewenste datum, tijd en gerechten haalbaar zijn.'
  },
  {
    q: 'Welke informatie moet ik meesturen?',
    a: 'Het helpt ons als u datum en gewenste tijd, het aantal personen en een idee van de gerechten of het type bestelling (afhalen of in het restaurant) meegeeft. Allergieën of de gelegenheid mag u ook gerust vermelden.'
  },
  {
    q: 'Kan ik het menu eerst bekijken?',
    a: 'Ja. Op de pagina /menu/ vindt u onze actuele kaart met döner, kapsalon, grillgerechten, Turkse pizza en meer. Voor grotere groepen denken we graag met u mee — voor grotere bestellingen is eerder aanvragen handig.'
  }
] as const;

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${CANONICAL}#webpage`,
  url: CANONICAL,
  name: c.pageTitle,
  description: c.pageDescription,
  inLanguage: 'nl',
  isPartOf: { '@id': `${SITE_ORIGIN}/#website` }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: c.breadcrumbHome, item: BUSINESS.website.nlUrl },
    { '@type': 'ListItem', position: 2, name: c.breadcrumbCurrent, item: CANONICAL }
  ]
};

const faqSchema = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: FAQ_ITEMS.map((it) => ({
    '@type': 'Question',
    name: it.q,
    acceptedAnswer: { '@type': 'Answer', text: it.a }
  }))
};
---

<BaseLayout
  lang="nl"
  title={c.pageTitle}
  description={c.pageDescription}
  skipLinkLabel={CONTENT_NL.skipLinkLabel}
  canonicalUrl={CANONICAL}
  alternateLanguages={[
    { hreflang: 'nl-NL', href: CANONICAL },
    { hreflang: 'tr-TR', href: TR_URL },
    { hreflang: 'x-default', href: CANONICAL }
  ]}
  openGraph={{
    type: 'website',
    locale: 'nl_NL',
    siteName: BUSINESS.canonicalName,
    image: ogImageUrl,
    imageAlt: 'KEYFO Restaurant & Cafe Schiedam',
    imageType: 'image/jpeg',
    imageWidth: 1200,
    imageHeight: 630,
    imageSecureUrl: ogImageUrl
  }}
  jsonLd={[webPageSchema, breadcrumbSchema, faqSchema]}
  mobileCta={{
    ariaLabel: CONTENT_NL.mobileCtaAriaLabel,
    labels: CONTENT_NL.mobileCtaShort,
    hrefs: {
      menu: '/menu/',
      whatsapp: BUSINESS.getWhatsAppUrl(CONTENT_NL.whatsappPrefill),
      call: BUSINESS.phoneTel,
      route: BUSINESS.googleMapsDirectionsUrl
    }
  }}
>
  <Header
    brand={BUSINESS.canonicalName}
    langLabel="TR"
    langAriaLabel="Wissel naar Turks"
    langHref={TR_URL}
    navAriaLabel={CONTENT_NL.navAriaLabel}
    nav={{
      menu: CONTENT_NL.nav.menu,
      popular: 'Populair',
      gallery: 'Galerij',
      location: CONTENT_NL.nav.locatie
    }}
    cta={{
      whatsapp: { label: 'Afhalen', href: BUSINESS.getWhatsAppUrl(CONTENT_NL.whatsappPrefill) },
      phone: { label: 'Bellen', href: BUSINESS.phoneTel }
    }}
  />

  <main id="main">
    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-container">
        <nav aria-label="Breadcrumb" class="keyfo-breadcrumb">
          <a href="/">{c.breadcrumbHome}</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{c.breadcrumbCurrent}</span>
        </nav>
        <header class="keyfo-menu-page-head">
          <span class="keyfo-menu-eyebrow">{c.eyebrow}</span>
          <h1 class="keyfo-menu-page-title keyfo-brand">{c.heading}</h1>
          <p class="keyfo-menu-page-lead">{c.lead}</p>
        </header>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container keyfo-req-container">
        <CateringForm locale="nl" sourcePage="groepsbestelling-schiedam" />
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container max-w-3xl space-y-8 leading-relaxed text-zinc-800">
        <div class="space-y-3">
          <h2 class="keyfo-section-title">Wat valt onder een groepsbestelling?</h2>
          <p>
            Een groepsaanvraag bij KEYFO is geschikt voor familie-etentjes, kantoor- en
            collega-bestellingen, vrienden die samen eten of een grotere afhaalbestelling voor
            een gelegenheid. U geeft ons een idee van het aantal personen, de gerechten en hoe u
            het wilt ontvangen — afhalen of in het restaurant — en wij denken met u mee.
          </p>
        </div>
        <div class="space-y-3">
          <h2 class="keyfo-section-title">Hoe werkt een groepsaanvraag via WhatsApp?</h2>
          <p>
            U vult het formulier hierboven in of stuurt rechtstreeks een WhatsApp. Vermeld het
            aantal personen, de gewenste datum en tijd, de gerechten waaraan u denkt en eventuele
            opmerkingen (allergieën, gelegenheid). KEYFO bekijkt de aanvraag en bevestigt de
            details via WhatsApp. Voor grotere groepen is eerder aanvragen handig — zo kunnen we
            voldoende voorbereiden. Liever inspiratie opdoen? Bekijk eerst de
            <a class="underline" href="/menu/">volledige menukaart</a>.
          </p>
        </div>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container">
        <FAQ heading="Veelgestelde vragen over groepsaanvragen" items={FAQ_ITEMS} />
      </div>
    </section>
  </main>

  <Footer
    brand={BUSINESS.canonicalName}
    tagline={CONTENT_NL.heroSubheading}
    napLines={[
      `Adres: ${BUSINESS.address.streetAddress}, ${BUSINESS.address.postalCode} ${BUSINESS.address.addressLocality}`,
      `Telefoon/WhatsApp: ${BUSINESS.phone}`,
      `E-mail: ${BUSINESS.email}`
    ]}
    columns={[
      {
        label: 'Acties',
        links: [
          { label: CONTENT_NL.ctas.whatsappPickup, href: BUSINESS.getWhatsAppUrl(CONTENT_NL.whatsappPrefill), isExternal: true },
          { label: CONTENT_NL.ctas.callNow, href: BUSINESS.phoneTel },
          { label: CONTENT_NL.ctas.viewRoute, href: BUSINESS.googleMapsDirectionsUrl, isExternal: true }
        ]
      },
      {
        label: 'Lokaal',
        links: [
          { label: 'Turks restaurant Schiedam', href: '/turks-restaurant-schiedam/' },
          { label: 'Reserveren', href: '/reserveren/' },
          { label: 'Groepsbestelling', href: '/groepsbestelling-schiedam/' }
        ]
      }
    ]}
    legalLine={`© ${new Date().getFullYear()} ${BUSINESS.canonicalName}`}
  />
</BaseLayout>
