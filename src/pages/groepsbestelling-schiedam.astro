---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CateringForm from '../components/CateringForm.astro';

import { BUSINESS } from '../data/business';
import { CONTENT_NL } from '../data/content.nl';

const SITE_ORIGIN = 'https://keyfo.nl';
const CANONICAL = `${SITE_ORIGIN}/groepsbestelling-schiedam/`;
const TR_URL = `${SITE_ORIGIN}/tr/toplu-gel-al-schiedam/`;
const ogImageUrl = `${SITE_ORIGIN}/assets/keyfo/og-keyfo.jpg`;

const c = CONTENT_NL.groepsbestelling;

const webPageSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  '@id': `${CANONICAL}#webpage`,
  url: CANONICAL,
  name: c.pageTitle,
  description: c.pageDescription,
  inLanguage: 'nl',
  isPartOf: { '@id': `${SITE_ORIGIN}/#website` }
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: c.breadcrumbHome, item: BUSINESS.website.nlUrl },
    { '@type': 'ListItem', position: 2, name: c.breadcrumbCurrent, item: CANONICAL }
  ]
};
---

<BaseLayout
  lang="nl"
  title={c.pageTitle}
  description={c.pageDescription}
  skipLinkLabel={CONTENT_NL.skipLinkLabel}
  canonicalUrl={CANONICAL}
  alternateLanguages={[
    { hreflang: 'nl-NL', href: CANONICAL },
    { hreflang: 'tr-TR', href: TR_URL },
    { hreflang: 'x-default', href: CANONICAL }
  ]}
  openGraph={{
    type: 'website',
    locale: 'nl_NL',
    siteName: BUSINESS.canonicalName,
    image: ogImageUrl,
    imageAlt: 'KEYFO Restaurant & Cafe Schiedam',
    imageType: 'image/jpeg',
    imageWidth: 1200,
    imageHeight: 630,
    imageSecureUrl: ogImageUrl
  }}
  jsonLd={[webPageSchema, breadcrumbSchema]}
  mobileCta={{
    ariaLabel: CONTENT_NL.mobileCtaAriaLabel,
    labels: CONTENT_NL.mobileCtaShort,
    hrefs: {
      menu: '/menu/',
      whatsapp: BUSINESS.getWhatsAppUrl(CONTENT_NL.whatsappPrefill),
      call: BUSINESS.phoneTel,
      route: BUSINESS.googleMapsDirectionsUrl
    }
  }}
>
  <Header
    brand={BUSINESS.canonicalName}
    langLabel="TR"
    langAriaLabel="Wissel naar Turks"
    langHref={TR_URL}
    navAriaLabel={CONTENT_NL.navAriaLabel}
    nav={{
      menu: CONTENT_NL.nav.menu,
      popular: 'Populair',
      gallery: 'Galerij',
      location: CONTENT_NL.nav.locatie
    }}
    cta={{
      whatsapp: { label: 'Afhalen', href: BUSINESS.getWhatsAppUrl(CONTENT_NL.whatsappPrefill) },
      phone: { label: 'Bellen', href: BUSINESS.phoneTel }
    }}
  />

  <main id="main">
    <section class="keyfo-section keyfo-band-dark">
      <div class="keyfo-container">
        <nav aria-label="Breadcrumb" class="keyfo-breadcrumb">
          <a href="/">{c.breadcrumbHome}</a>
          <span aria-hidden="true">›</span>
          <span aria-current="page">{c.breadcrumbCurrent}</span>
        </nav>
        <header class="keyfo-menu-page-head">
          <span class="keyfo-menu-eyebrow">{c.eyebrow}</span>
          <h1 class="keyfo-menu-page-title keyfo-brand">{c.heading}</h1>
          <p class="keyfo-menu-page-lead">{c.lead}</p>
        </header>
      </div>
    </section>

    <section class="keyfo-section keyfo-band-cream">
      <div class="keyfo-container keyfo-req-container">
        <CateringForm locale="nl" sourcePage="groepsbestelling-schiedam" />
      </div>
    </section>
  </main>

  <Footer
    brand={BUSINESS.canonicalName}
    tagline={CONTENT_NL.heroSubheading}
    napLines={[
      `Adres: ${BUSINESS.address.streetAddress}, ${BUSINESS.address.postalCode} ${BUSINESS.address.addressLocality}`,
      `Telefoon/WhatsApp: ${BUSINESS.phone}`,
      `E-mail: ${BUSINESS.email}`
    ]}
    columns={[
      {
        label: 'Acties',
        links: [
          { label: CONTENT_NL.ctas.whatsappPickup, href: BUSINESS.getWhatsAppUrl(CONTENT_NL.whatsappPrefill), isExternal: true },
          { label: CONTENT_NL.ctas.callNow, href: BUSINESS.phoneTel },
          { label: CONTENT_NL.ctas.viewRoute, href: BUSINESS.googleMapsDirectionsUrl, isExternal: true }
        ]
      },
      {
        label: 'Lokaal',
        links: [
          { label: 'Turks restaurant Schiedam', href: '/turks-restaurant-schiedam/' },
          { label: 'Reserveren', href: '/reserveren/' },
          { label: 'Groepsbestelling', href: '/groepsbestelling-schiedam/' }
        ]
      }
    ]}
    legalLine={`© ${new Date().getFullYear()} ${BUSINESS.canonicalName}`}
  />
</BaseLayout>
