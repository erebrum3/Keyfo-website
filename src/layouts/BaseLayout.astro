---
import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';
import SpeedInsights from '@vercel/speed-insights/astro';
import CookieConsent from '../components/CookieConsent.astro';
import MaintenanceOverlay from '../components/MaintenanceOverlay.astro';

type MobileCta = {
  ariaLabel: string;
  labels: { menu: string; whatsapp: string; call: string; route: string };
  hrefs: { menu: string; whatsapp: string; call: string; route: string };
};

type AlternateLanguage = {
  hreflang: string;
  href: string;
};

type OpenGraph = {
  type?: string;
  locale?: string;
  siteName?: string;
  image?: string;
  imageAlt?: string;
  imageWidth?: number;
  imageHeight?: number;
  imageType?: string;
  imageSecureUrl?: string;
};

type Props = {
  lang: string;
  title: string;
  description: string;
  skipLinkLabel: string;
  canonicalUrl?: string;
  alternateLanguages?: AlternateLanguage[];
  openGraph?: OpenGraph;
  jsonLd?: unknown[];
  mobileCta?: MobileCta;
};

const {
  lang,
  title,
  description,
  skipLinkLabel,
  canonicalUrl,
  alternateLanguages = [],
  openGraph,
  jsonLd = [],
  mobileCta
} = Astro.props;

const ogType = openGraph?.type ?? 'website';
const ogLocale = openGraph?.locale ?? (lang === 'tr' ? 'tr_TR' : 'nl_NL');
const ogSiteName = openGraph?.siteName ?? 'KEYFO Restaurant & Cafe';
const ogImage = openGraph?.image;
const ogImageAlt = openGraph?.imageAlt ?? title;
const ogImageWidth = openGraph?.imageWidth;
const ogImageHeight = openGraph?.imageHeight;
const ogImageType = openGraph?.imageType;
const ogImageSecureUrl = openGraph?.imageSecureUrl ?? (ogImage && ogImage.startsWith('https://') ? ogImage : undefined);

const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION;
const bingSiteVerification = import.meta.env.PUBLIC_BING_SITE_VERIFICATION;
const ga4MeasurementId = import.meta.env.PUBLIC_GA4_MEASUREMENT_ID;
const clarityProjectId = import.meta.env.PUBLIC_CLARITY_PROJECT_ID;
const maintenanceOverlayActive = import.meta.env.PUBLIC_KEYFO_NOTICE_MODE === 'maintenance_overlay';
const maintenanceOverlayLang: 'nl' | 'tr' = lang === 'tr' ? 'tr' : 'nl';
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="robots" content="index, follow" />
    {googleSiteVerification ? <meta name="google-site-verification" content={googleSiteVerification} /> : null}
    {bingSiteVerification ? <meta name="msvalidate.01" content={bingSiteVerification} /> : null}
    <meta name="theme-color" content="#0c0806" media="(prefers-color-scheme: dark)" />
    <meta name="theme-color" content="#fff6e5" media="(prefers-color-scheme: light)" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {canonicalUrl ? <link rel="canonical" href={canonicalUrl} /> : null}

    {alternateLanguages.map((alt) => (
      <link rel="alternate" hreflang={alt.hreflang} href={alt.href} />
    ))}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={ogSiteName} />
    <meta property="og:locale" content={ogLocale} />
    {alternateLanguages
      .filter((alt) => alt.hreflang !== 'x-default')
      .map((alt) => {
        const altLocale = alt.hreflang === 'tr-TR' ? 'tr_TR' : alt.hreflang === 'nl-NL' ? 'nl_NL' : null;
        if (!altLocale || altLocale === ogLocale) return null;
        return <meta property="og:locale:alternate" content={altLocale} />;
      })}
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {canonicalUrl ? <meta property="og:url" content={canonicalUrl} /> : null}
    {ogImage ? <meta property="og:image" content={ogImage} /> : null}
    {ogImageSecureUrl ? <meta property="og:image:secure_url" content={ogImageSecureUrl} /> : null}
    {ogImage && ogImageType ? <meta property="og:image:type" content={ogImageType} /> : null}
    {ogImage && ogImageWidth ? <meta property="og:image:width" content={String(ogImageWidth)} /> : null}
    {ogImage && ogImageHeight ? <meta property="og:image:height" content={String(ogImageHeight)} /> : null}
    {ogImage ? <meta property="og:image:alt" content={ogImageAlt} /> : null}

    <meta name="twitter:card" content={ogImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {ogImage ? <meta name="twitter:image" content={ogImage} /> : null}
    {ogImage ? <meta name="twitter:image:alt" content={ogImageAlt} /> : null}

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <link
      rel="preload"
      as="image"
      href="/assets/keyfo/hero/storefront-desktop-1200.webp"
      imagesrcset="/assets/keyfo/hero/storefront-mobile-800.webp 800w, /assets/keyfo/hero/storefront-desktop-1200.webp 1200w, /assets/keyfo/hero/storefront-desktop-1600.webp 1600w"
      imagesizes="(max-width: 767px) 100vw, (min-width: 1100px) 540px, 45vw"
      fetchpriority="high"
    />

    {jsonLd.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

  </head>
  <body class="min-h-screen pb-24 sm:pb-0">
    <a
      class="sr-only focus:not-sr-only fixed left-4 top-4 z-[60] rounded bg-white px-3 py-2 text-sm text-zinc-950 shadow"
      href="#main"
    >
      {skipLinkLabel}
    </a>
    <slot />

    {mobileCta ? (
      <nav
        aria-label={mobileCta.ariaLabel}
        class="keyfo-mobile-cta fixed inset-x-0 bottom-0 z-40 border-t border-white/10 bg-zinc-950/95 backdrop-blur supports-[backdrop-filter]:bg-zinc-950/78 sm:hidden"
      >
        <div class="grid grid-cols-4 divide-x divide-white/10">
          <a class="keyfo-mobile-cta-link" href={mobileCta.hrefs.menu} data-event="click_menu" data-cta-location="mobile_bar">{mobileCta.labels.menu}</a>
          <a class="keyfo-mobile-cta-link keyfo-mobile-cta-primary" href={mobileCta.hrefs.whatsapp} data-event="click_whatsapp" data-cta-location="mobile_bar">{mobileCta.labels.whatsapp}</a>
          <a class="keyfo-mobile-cta-link" href={mobileCta.hrefs.call} data-event="click_phone" data-cta-location="mobile_bar">{mobileCta.labels.call}</a>
          <a class="keyfo-mobile-cta-link" href={mobileCta.hrefs.route} data-event="click_route" data-cta-location="mobile_bar">{mobileCta.labels.route}</a>
        </div>
      </nav>
    ) : null}

    <CookieConsent lang={lang === 'tr' ? 'tr' : 'nl'} ga4MeasurementId={ga4MeasurementId} />

    {maintenanceOverlayActive ? <MaintenanceOverlay lang={maintenanceOverlayLang} /> : null}

    <script>
      import '../scripts/reveal.ts';
      import { bindAutoTracking } from '../scripts/analytics';
      bindAutoTracking();
    </script>

    {clarityProjectId ? (
      <script define:vars={{ clarityProjectId }}>
        (function () {
          var started = false;
          async function startClarity() {
            if (started) return;
            started = true;
            try {
              var mod = await import('@microsoft/clarity');
              var Clarity = mod.default || mod;
              Clarity.init(clarityProjectId);
            } catch (_e) { /* ignore */ }
          }
          var consent = null;
          try { consent = localStorage.getItem('keyfo_cookie_consent'); } catch (_e) {}
          if (consent === 'accepted') {
            startClarity();
          } else {
            document.addEventListener('keyfo:consent-changed', function (e) {
              if (e && e.detail && e.detail.consent === 'accepted') startClarity();
            });
          }
        })();
      </script>
    ) : null}

    <Analytics />
    <SpeedInsights />
  </body>
</html>
