---
type Props = {
  heading: string;
  eyebrow?: string;
  intro?: string;
  addressLines: string[];
  hoursLine?: string;
  addressLabel?: string;
  contactLabel?: string;
  parkingLine?: string;
  links: Array<{ label: string; href: string; isExternal?: boolean; variant?: 'primary' | 'secondary' | 'tertiary' }>;
  mapEmbedUrl: string;
  mapDirectionsUrl: string;
  mapTitle?: string;
  mapCtaLabel: string;
};

const {
  heading,
  eyebrow,
  intro,
  addressLines,
  hoursLine,
  addressLabel = 'Adres',
  contactLabel = 'Acties',
  parkingLine,
  links,
  mapEmbedUrl,
  mapDirectionsUrl,
  mapTitle = 'KEYFO',
  mapCtaLabel
} = Astro.props;
---

<section id="location" aria-labelledby="location-heading" class="keyfo-location">
  <div class="keyfo-location-card">
    <header class="keyfo-location-head">
      {eyebrow ? <span class="keyfo-location-eyebrow">{eyebrow}</span> : null}
      <h2 id="location-heading" class="keyfo-section-title text-white">{heading}</h2>
      {intro ? <p class="keyfo-location-intro">{intro}</p> : null}
    </header>

    <div class="keyfo-location-grid">
      <div class="keyfo-location-info">
        <div class="keyfo-location-block">
          <span class="keyfo-location-label">{addressLabel}</span>
          <address class="keyfo-location-address">
            {addressLines.map((line) => (
              <span class="keyfo-location-line">{line}</span>
            ))}
          </address>
          {hoursLine ? <span class="keyfo-location-meta">{hoursLine}</span> : null}
          {parkingLine ? <span class="keyfo-location-meta keyfo-location-meta--muted">{parkingLine}</span> : null}
        </div>

        <div class="keyfo-location-block keyfo-location-actions-block">
          <span class="keyfo-location-label">{contactLabel}</span>
          <ul class="keyfo-location-actions">
            {links.map((l) => (
              <li>
                <a
                  class={
                    l.variant === 'tertiary'
                      ? 'keyfo-btn-ghost text-zinc-300'
                      : l.variant === 'primary'
                        ? 'keyfo-btn-primary keyfo-glow-amber'
                        : 'keyfo-btn-secondary'
                  }
                  href={l.href}
                  target={l.isExternal ? '_blank' : undefined}
                  rel={l.isExternal ? 'noopener noreferrer' : undefined}
                >
                  {l.label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <div
        class="keyfo-location-map"
        data-map-facade
        data-map-src={mapEmbedUrl}
        data-map-title={`${mapTitle} — ${addressLines.join(', ')}`}
      >
        <div class="keyfo-location-map-placeholder" aria-hidden="true">
          <svg viewBox="0 0 64 64" width="48" height="48" focusable="false" aria-hidden="true">
            <path fill="rgba(242, 176, 43, 0.85)" d="M32 4c-9.94 0-18 8.06-18 18 0 13.5 18 38 18 38s18-24.5 18-38c0-9.94-8.06-18-18-18Zm0 25a7 7 0 1 1 0-14 7 7 0 0 1 0 14Z"/>
          </svg>
          <span class="keyfo-location-map-placeholder-text">{addressLines[0]}</span>
        </div>
        <button
          type="button"
          class="keyfo-location-map-load"
          data-map-load
          aria-label={mapTitle ? `${mapTitle} — kaart laden` : 'Kaart laden'}
        >
          <span>Kaart bekijken</span>
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M9.293 3.293a1 1 0 0 1 1.414 0l4 4a1 1 0 0 1 0 1.414l-4 4a1 1 0 0 1-1.414-1.414L11.586 9H3a1 1 0 1 1 0-2h8.586L9.293 4.707a1 1 0 0 1 0-1.414Z"/>
          </svg>
        </button>
        <a
          class="keyfo-location-map-cta"
          href={mapDirectionsUrl}
          target="_blank"
          rel="noopener noreferrer"
          aria-label={mapCtaLabel}
        >
          <span aria-hidden="true">{mapCtaLabel}</span>
          <svg viewBox="0 0 16 16" width="14" height="14" aria-hidden="true" focusable="false">
            <path fill="currentColor" d="M9.293 3.293a1 1 0 0 1 1.414 0l4 4a1 1 0 0 1 0 1.414l-4 4a1 1 0 0 1-1.414-1.414L11.586 9H3a1 1 0 1 1 0-2h8.586L9.293 4.707a1 1 0 0 1 0-1.414Z"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  const facades = document.querySelectorAll<HTMLElement>('[data-map-facade]');
  facades.forEach((facade) => {
    const btn = facade.querySelector<HTMLButtonElement>('[data-map-load]');
    const src = facade.getAttribute('data-map-src');
    const title = facade.getAttribute('data-map-title') ?? 'Kaart';
    if (!btn || !src) return;

    let loaded = false;
    const load = () => {
      if (loaded) return;
      loaded = true;
      const iframe = document.createElement('iframe');
      iframe.src = src;
      iframe.title = title;
      iframe.setAttribute('loading', 'lazy');
      iframe.setAttribute('referrerpolicy', 'no-referrer-when-downgrade');
      iframe.setAttribute('allowfullscreen', '');
      iframe.className = 'keyfo-location-map-iframe';
      const placeholder = facade.querySelector('.keyfo-location-map-placeholder');
      placeholder?.remove();
      btn.remove();
      facade.prepend(iframe);
    };

    btn.addEventListener('click', load, { once: true });
  });
</script>
