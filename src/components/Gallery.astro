---
type Props = {
  heading: string;
  introText: string;
  eyebrow?: string;
  items: Array<{ src: string; alt: string }>;
};

const { heading, introText, eyebrow, items } = Astro.props;

// Mosaic slots — visitor walking flow:
// 0 interior-wide (anchor, mobile full-width, desktop 2x2)
// 1 hero-interior (seating, desktop tall column)
// 2 interior-wall-art (wall decor, desktop tall column)
// 3 family-corner (horizontal wide row)
// 4 drinks-corner (small)
// 5 table-detail (small, closing detail)
const slots = [
  'col-span-2 lg:col-span-2 lg:row-span-2',
  'lg:col-span-1 lg:row-span-2',
  'lg:col-span-1 lg:row-span-2',
  'col-span-2 lg:col-span-2 lg:row-span-1',
  'lg:col-span-1 lg:row-span-1',
  'lg:col-span-1 lg:row-span-1'
];

const imageDimensions: Record<string, { width: number; height: number }> = {
  '/assets/keyfo/interior-wide.jpg': { width: 1200, height: 1600 },
  '/assets/keyfo/hero-interior.jpg': { width: 1200, height: 1600 },
  '/assets/keyfo/interior-wall-art.jpg': { width: 1200, height: 1600 },
  '/assets/keyfo/family-corner.jpg': { width: 1600, height: 1200 },
  '/assets/keyfo/drinks-corner.jpg': { width: 1200, height: 1600 },
  '/assets/keyfo/table-detail.jpg': { width: 1600, height: 1196 }
};
---

<section aria-labelledby="gallery-heading" class="keyfo-gallery">
  <header class="keyfo-gallery-head">
    {eyebrow ? <span class="keyfo-gallery-eyebrow">{eyebrow}</span> : null}
    <h2 id="gallery-heading" class="keyfo-section-title">{heading}</h2>
    <p class="keyfo-gallery-intro">{introText}</p>
  </header>

  <div class="keyfo-gallery-grid">
    {items.map((slot, idx) => {
      const span = slots[idx % slots.length];
      const dimensions = imageDimensions[slot.src];
      const stem = slot.src.replace(/\.jpe?g$/i, '');
      const avifSrc = `${stem}.avif`;
      const webpSrc = `${stem}.webp`;
      return (
        <figure class:list={['keyfo-gallery-cell', span]}>
          <div class="keyfo-gallery-frame">
            <picture>
              <source srcset={avifSrc} type="image/avif" />
              <source srcset={webpSrc} type="image/webp" />
              <img
                src={slot.src}
                alt={slot.alt}
                width={dimensions?.width}
                height={dimensions?.height}
                loading="lazy"
                decoding="async"
                class="keyfo-gallery-img"
                onerror="this.style.display='none'"
              />
            </picture>
          </div>
          <figcaption class="sr-only">{slot.alt}</figcaption>
        </figure>
      );
    })}
  </div>
</section>
