---
import type { MenuCategory } from '../data/menu';
import { BUSINESS } from '../data/business';
import { CONTENT_NL } from '../data/content.nl';
import { CONTENT_TR } from '../data/content.tr';

type Props = {
  heading: string;
  eyebrow?: string;
  categories: Array<MenuCategory & { title: string }>;
  formatPrice: (priceEur: number) => string;
  lastUpdatedLabel: string;
  lastUpdated: string;
  notes: string[];
  showDescriptions?: boolean;
  showAfhaalActions?: boolean;
};

const { heading, eyebrow, categories, formatPrice, lastUpdatedLabel, lastUpdated, notes, showDescriptions = false, showAfhaalActions = false } = Astro.props;

const isTr = Astro.url.pathname.startsWith('/tr');
const descKey = isTr ? 'Tr' : 'Nl';
const getDescription = (item: typeof categories[number]['items'][number]) => {
  if (!showDescriptions) return null;
  const longKey = `longDescription${descKey}` as 'longDescriptionNl' | 'longDescriptionTr';
  const shortKey = `description${descKey}` as 'descriptionNl' | 'descriptionTr';
  return item[longKey] ?? item[shortKey] ?? null;
};
const localeContent = isTr ? CONTENT_TR : CONTENT_NL;
const menuCta = localeContent.menuCta;
const whatsappHref = BUSINESS.getWhatsAppUrl(localeContent.whatsappPrefill);
const callHref = BUSINESS.phoneTel;
const addLabel = `+ ${localeContent.afhaal.addLabel}`;
const addedLabel = `✓ ${localeContent.afhaal.addedLabel}`;
---

<section id="menu" aria-labelledby="menu-heading" class="keyfo-menu-frame">
  <div class="keyfo-menu">
  <div class="keyfo-menu-head">
    <div>
      {eyebrow ? <span class="keyfo-menu-eyebrow">{eyebrow}</span> : null}
      <h2 id="menu-heading" class="keyfo-menu-title keyfo-brand">{heading}</h2>
    </div>
    <span class="keyfo-menu-meta">{lastUpdatedLabel}: {lastUpdated}</span>
  </div>

  {localeContent.menuIntro ? (
    <p class="keyfo-menu-intro">{localeContent.menuIntro}</p>
  ) : null}

  <nav class="keyfo-menu-shortcuts" aria-label={localeContent.menuShortcutLabel}>
    <ul class="keyfo-menu-shortcuts-list">
      {categories.map((cat) => (
        <li>
          <a class="keyfo-menu-shortcut" href={`#cat-${cat.id}`}>{cat.title}</a>
        </li>
      ))}
    </ul>
  </nav>

  <div class="keyfo-menu-grid">
    {categories.map((cat, idx) => (
      <section aria-labelledby={`cat-${cat.id}`} class="keyfo-menu-cat">
        <header class="keyfo-menu-cat-head">
          <span class="keyfo-menu-cat-num keyfo-tabular">{String(idx + 1).padStart(2, '0')}</span>
          <h3 id={`cat-${cat.id}`} class="keyfo-menu-cat-title keyfo-brand">{cat.title}</h3>
          <span aria-hidden="true" class="keyfo-menu-cat-rule"></span>
        </header>

        <ul class="keyfo-menu-list">
          {cat.items.map((item) => {
            const desc = getDescription(item);
            return (
              <li class={`keyfo-menu-row${desc ? ' keyfo-menu-row--with-desc' : ''}${showAfhaalActions ? ' keyfo-menu-row--with-action' : ''}`}>
                <span class="keyfo-menu-name">{item.name}</span>
                <span aria-hidden="true" class="keyfo-menu-leader"></span>
                <span class="keyfo-menu-price keyfo-tabular">{formatPrice(item.priceEur)}</span>
                {desc ? <p class="keyfo-menu-desc">{desc}</p> : null}
                {showAfhaalActions ? (
                  <button
                    type="button"
                    class="keyfo-add-btn"
                    data-afhaal-add
                    data-item-id={item.id}
                    data-label-default={addLabel}
                    data-label-added={addedLabel}
                    data-event="add_to_afhaal"
                    data-cta-location="menu_section"
                    data-item-name={isTr ? item.nameTr : item.nameNl}
                    data-item-category={cat.id}
                    aria-label={`${addLabel} — ${isTr ? item.nameTr : item.nameNl}`}
                  >
                    <span class="keyfo-add-btn-text">{addLabel}</span>
                  </button>
                ) : null}
              </li>
            );
          })}
        </ul>
      </section>
    ))}
  </div>

  {notes.length > 0 ? (
    <div class="keyfo-menu-notes">
      {notes.map((n) => (
        <p class="keyfo-menu-note">{n}</p>
      ))}
    </div>
  ) : null}

  <div class="keyfo-menu-cta" role="group" aria-label={menuCta.heading}>
    <p class="keyfo-menu-cta-heading">{menuCta.heading}</p>
    <div class="keyfo-menu-cta-actions">
      <a class="keyfo-btn-primary" href={whatsappHref} target="_blank" rel="noopener noreferrer" data-event="click_whatsapp" data-cta-location="menu_section">{menuCta.whatsappLabel}</a>
      <a class="keyfo-btn-secondary" href={callHref} data-event="click_phone" data-cta-location="menu_section">{menuCta.callLabel}</a>
    </div>
  </div>

  <p class="keyfo-menu-stamp" aria-hidden="true">KEYFO · RESTAURANT &amp; CAFE</p>
  </div>
</section>

<script is:inline>
  (() => {
    const chips = document.querySelectorAll('.keyfo-menu-shortcut');
    if (!chips.length || !('IntersectionObserver' in window)) return;
    const byId = new Map();
    chips.forEach((chip) => {
      const href = chip.getAttribute('href') || '';
      if (href.startsWith('#')) byId.set(href.slice(1), chip);
    });
    const targets = Array.from(byId.keys()).map((id) => document.getElementById(id)).filter(Boolean);
    if (!targets.length) return;
    const setActive = (id) => {
      chips.forEach((c) => c.classList.toggle('is-active', byId.get(id) === c));
    };
    const observer = new IntersectionObserver((entries) => {
      const visible = entries.filter((e) => e.isIntersecting).sort((a, b) => a.boundingClientRect.top - b.boundingClientRect.top);
      if (visible.length) setActive(visible[0].target.id);
    }, { rootMargin: '-104px 0px -55% 0px', threshold: 0 });
    targets.forEach((t) => observer.observe(t));
  })();
</script>

<script>
  import { addItem } from '../scripts/afhaal-cart';

  const ADDED_FEEDBACK_MS = 1500;

  document.addEventListener('click', (event) => {
    const target = event.target as Element | null;
    if (!target) return;
    const btn = target.closest<HTMLButtonElement>('[data-afhaal-add]');
    if (!btn) return;
    const itemId = btn.getAttribute('data-item-id');
    if (!itemId) return;
    addItem(itemId, 1);
    const textEl = btn.querySelector<HTMLElement>('.keyfo-add-btn-text');
    const defaultLabel = btn.getAttribute('data-label-default') ?? '';
    const addedLabel = btn.getAttribute('data-label-added') ?? defaultLabel;
    if (textEl && !btn.classList.contains('is-added')) {
      btn.classList.add('is-added');
      textEl.textContent = addedLabel;
      window.setTimeout(() => {
        btn.classList.remove('is-added');
        textEl.textContent = defaultLabel;
      }, ADDED_FEEDBACK_MS);
    }
  });
</script>
