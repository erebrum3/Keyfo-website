---
type Props = {
  heading: string;
  subheading: string;
  kicker: string;
  ops?: string;
  rating?: {
    value: number;
    count: number;
    label: string;
    ariaLabel: string;
    url?: string | null;
  };
  ctas: {
    viewMenu: { label: string; href: string };
    whatsapp: { label: string; href: string };
    phone: { label: string; href: string };
    route: { label: string; href: string };
  };
  photoAlt?: string;
};

const {
  heading,
  subheading,
  kicker,
  ops,
  rating,
  ctas,
  photoAlt = 'Voorgevel van KEYFO Restaurant & Cafe in Schiedam Centrum — terras met tafels en stoelen.'
} = Astro.props;
const ratingValueLabel = rating ? rating.value.toFixed(1) : '';

const heroMain = heading.replace(/\s*Restaurant\s*&\s*Cafe\s*/i, '').trim() || heading;
const heroSubbrand = heroMain === heading ? '' : heading.replace(heroMain, '').trim();
---

<section aria-labelledby="hero-title" class="keyfo-hero relative">
  <span aria-hidden="true" class="keyfo-hero-rule"></span>

  <div class="keyfo-hero-grid">
    <div class="keyfo-hero-inner">
    <div class="keyfo-hero-meta keyfo-anim-fade-up">
      <span aria-hidden="true" class="keyfo-hero-meta-dot"></span>
      <span class="keyfo-hero-meta-kicker">{kicker}</span>
      {rating ? (
        <>
          <span aria-hidden="true" class="keyfo-hero-meta-sep">·</span>
          {rating.url ? (
            <a
              href={rating.url}
              target="_blank"
              rel="noopener noreferrer"
              class="keyfo-hero-meta-rating"
              aria-label={`${ratingValueLabel} — ${rating.ariaLabel}: ${ratingValueLabel} / 5 (${rating.count} ${rating.label})`}
            >
              <span aria-hidden="true" class="keyfo-hero-meta-star">★</span>
              <span class="keyfo-hero-meta-value">{ratingValueLabel}</span>
              <span aria-hidden="true" class="keyfo-hero-meta-mid">·</span>
              <span class="keyfo-hero-meta-count">{rating.count} {rating.label}</span>
            </a>
          ) : (
            <span
              class="keyfo-hero-meta-rating"
              aria-label={`${ratingValueLabel} — ${rating.ariaLabel}: ${ratingValueLabel} / 5 (${rating.count} ${rating.label})`}
            >
              <span aria-hidden="true" class="keyfo-hero-meta-star">★</span>
              <span class="keyfo-hero-meta-value">{ratingValueLabel}</span>
              <span aria-hidden="true" class="keyfo-hero-meta-mid">·</span>
              <span class="keyfo-hero-meta-count">{rating.count} {rating.label}</span>
            </span>
          )}
        </>
      ) : null}
    </div>

    <h1 id="hero-title" class="keyfo-brand keyfo-hero-title keyfo-anim-fade-up keyfo-anim-delay-1">
      {heroMain}
    </h1>

    {heroSubbrand ? (
      <div class="keyfo-hero-subbrand keyfo-anim-fade-up keyfo-anim-delay-2">
        <span aria-hidden="true" class="keyfo-hero-subbrand-rule"></span>
        <span>{heroSubbrand}</span>
      </div>
    ) : null}

    <p class="keyfo-hero-sub keyfo-anim-fade-up keyfo-anim-delay-2">{subheading}</p>

    {ops ? (
      <p class="keyfo-hero-ops keyfo-anim-fade-up keyfo-anim-delay-3">
        <svg
          aria-hidden="true"
          class="keyfo-hero-ops-icon"
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
          <circle cx="12" cy="10" r="3"/>
        </svg>
        <span>{ops}</span>
      </p>
    ) : null}

    <div class="keyfo-hero-ctas keyfo-anim-fade-up keyfo-anim-delay-4">
      <a href={ctas.whatsapp.href} class="keyfo-btn-primary keyfo-btn-hero keyfo-glow-amber keyfo-motion" data-event="click_whatsapp" data-cta-location="hero">
        {ctas.whatsapp.label}
      </a>
      <div class="keyfo-hero-cta-group">
        <a href={ctas.viewMenu.href} class="keyfo-btn-secondary keyfo-motion" data-event="click_menu" data-cta-location="hero">{ctas.viewMenu.label}</a>
        <a href={ctas.phone.href} class="keyfo-btn-secondary keyfo-motion" data-event="click_phone" data-cta-location="hero">{ctas.phone.label}</a>
        <a href={ctas.route.href} class="keyfo-btn-secondary keyfo-motion" data-event="click_route" data-cta-location="hero">{ctas.route.label}</a>
      </div>
    </div>
    </div>

    <picture class="keyfo-hero-photo keyfo-anim-fade-up keyfo-anim-delay-3">
      <source
        media="(max-width: 767px)"
        srcset="/assets/keyfo/hero/storefront-mobile-800.webp"
        type="image/webp"
      />
      <source
        media="(min-width: 768px)"
        srcset="/assets/keyfo/hero/storefront-desktop-1200.webp 1200w, /assets/keyfo/hero/storefront-desktop-1600.webp 1600w"
        sizes="(min-width: 1100px) 540px, (min-width: 768px) 45vw, 100vw"
        type="image/webp"
      />
      <img
        src="/assets/keyfo/hero/storefront-desktop-1200.webp"
        alt={photoAlt}
        width="1200"
        height="900"
        decoding="async"
        fetchpriority="high"
      />
    </picture>
  </div>
</section>
