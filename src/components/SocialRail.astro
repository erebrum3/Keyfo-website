---
import { BUSINESS } from '../data/business';

type Props = {
  lang?: 'nl' | 'tr';
};

const { lang = 'nl' } = Astro.props;

const labels = {
  nl: { aria: 'Sociale media' },
  tr: { aria: 'Sosyal medya' }
}[lang];

const items = [
  { key: 'instagram', href: BUSINESS.social.instagram, label: 'Instagram' },
  { key: 'facebook', href: BUSINESS.social.facebook, label: 'Facebook' },
  { key: 'tiktok', href: BUSINESS.social.tiktok, label: 'TikTok' },
  { key: 'twitter', href: BUSINESS.social.twitter, label: 'X (Twitter)' },
  { key: 'pinterest', href: BUSINESS.social.pinterest, label: 'Pinterest' }
] as const;
---

<aside
  aria-label={labels.aria}
  class="keyfo-social-rail fixed left-2 sm:left-3 top-1/2 z-40 flex -translate-y-1/2 flex-col gap-1.5 sm:gap-2 rounded-full border border-white/15 bg-zinc-950/70 p-1.5 sm:p-2 shadow-lg shadow-black/30 backdrop-blur supports-[backdrop-filter]:bg-zinc-950/55"
>
  {items.map((item) => (
    <a
      href={item.href}
      target="_blank"
      rel="noopener noreferrer"
      aria-label={item.label}
      title={item.label}
      class="group inline-flex h-8 w-8 sm:h-9 sm:w-9 items-center justify-center rounded-full text-white/80 transition hover:bg-white/15 hover:text-white focus-visible:bg-white/15 focus-visible:text-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-white/40"
    >
      <span class="sr-only">{item.label}</span>
      {item.key === 'instagram' && (
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="currentColor">
          <path d="M12 2.2c3.2 0 3.584.012 4.85.07 1.366.062 2.633.34 3.608 1.315.974.975 1.253 2.242 1.315 3.608.058 1.266.07 1.65.07 4.85s-.012 3.584-.07 4.85c-.062 1.366-.34 2.633-1.315 3.608-.975.974-2.242 1.253-3.608 1.315-1.266.058-1.65.07-4.85.07s-3.584-.012-4.85-.07c-1.366-.062-2.633-.34-3.608-1.315-.974-.975-1.253-2.242-1.315-3.608C2.212 15.584 2.2 15.2 2.2 12s.012-3.584.07-4.85c.062-1.366.34-2.633 1.315-3.608.975-.974 2.242-1.253 3.608-1.315C8.416 2.212 8.8 2.2 12 2.2zm0 1.8c-3.149 0-3.516.012-4.756.069-1.014.046-1.566.215-1.932.358-.486.189-.832.414-1.196.778-.364.364-.59.71-.778 1.196-.143.366-.312.918-.358 1.932C3.012 8.484 3 8.851 3 12s.012 3.516.069 4.756c.046 1.014.215 1.566.358 1.932.189.486.414.832.778 1.196.364.364.71.59 1.196.778.366.143.918.312 1.932.358 1.24.057 1.607.069 4.756.069s3.516-.012 4.756-.069c1.014-.046 1.566-.215 1.932-.358.486-.189.832-.414 1.196-.778.364-.364.59-.71.778-1.196.143-.366.312-.918.358-1.932.057-1.24.069-1.607.069-4.756s-.012-3.516-.069-4.756c-.046-1.014-.215-1.566-.358-1.932-.189-.486-.414-.832-.778-1.196-.364-.364-.71-.59-1.196-.778-.366-.143-.918-.312-1.932-.358C15.516 4.012 15.149 4 12 4zm0 3.3a4.7 4.7 0 110 9.4 4.7 4.7 0 010-9.4zm0 1.8a2.9 2.9 0 100 5.8 2.9 2.9 0 000-5.8zm5.05-2.1a1.1 1.1 0 110 2.2 1.1 1.1 0 010-2.2z"/>
        </svg>
      )}
      {item.key === 'facebook' && (
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="currentColor">
          <path d="M13.5 21.95v-8.6h2.9l.43-3.36h-3.33V7.85c0-.97.27-1.63 1.66-1.63h1.78V3.21c-.31-.04-1.37-.13-2.6-.13-2.57 0-4.33 1.57-4.33 4.45v2.46H7.1v3.36h2.91v8.6h3.49z"/>
        </svg>
      )}
      {item.key === 'tiktok' && (
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="currentColor">
          <path d="M16.6 5.82a4.83 4.83 0 01-3.36-1.4 4.83 4.83 0 01-1.4-3.27V1h-3.18v13.06a2.6 2.6 0 11-2.6-2.6c.18 0 .35.02.52.05V8.27a5.83 5.83 0 00-.52-.02 5.78 5.78 0 105.78 5.78V8.86a8.02 8.02 0 004.76 1.55V7.23c-.01 0-.01 0 0 0z"/>
        </svg>
      )}
      {item.key === 'twitter' && (
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="currentColor">
          <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77z"/>
        </svg>
      )}
      {item.key === 'pinterest' && (
        <svg viewBox="0 0 24 24" aria-hidden="true" class="h-4 w-4" fill="currentColor">
          <path d="M12 2.04A9.96 9.96 0 002.04 12c0 4.24 2.65 7.86 6.39 9.31-.09-.79-.17-2.01.04-2.87.18-.79 1.17-5.02 1.17-5.02s-.3-.6-.3-1.49c0-1.39.81-2.43 1.81-2.43.86 0 1.27.64 1.27 1.41 0 .86-.55 2.15-.83 3.35-.24 1 .5 1.81 1.49 1.81 1.79 0 3.17-1.89 3.17-4.62 0-2.41-1.74-4.1-4.22-4.1-2.87 0-4.56 2.16-4.56 4.39 0 .87.33 1.8.75 2.31.08.1.09.19.07.29-.08.32-.25 1-.28 1.14-.04.18-.15.23-.34.14-1.25-.58-2.03-2.4-2.03-3.87 0-3.15 2.29-6.04 6.6-6.04 3.46 0 6.15 2.47 6.15 5.77 0 3.44-2.17 6.21-5.18 6.21-1.01 0-1.97-.53-2.29-1.15l-.62 2.37c-.23.87-.83 1.96-1.24 2.62A9.96 9.96 0 0021.96 12 9.96 9.96 0 0012 2.04z"/>
        </svg>
      )}
    </a>
  ))}
</aside>
