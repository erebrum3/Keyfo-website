---
import type { MenuItem } from '../data/menu';

type Props = {
  heading: string;
  eyebrow?: string;
  lead?: string;
  ctaLabel?: string;
  ctaHref?: string;
  items: Array<MenuItem & { priceLabel: string; categoryTitle?: string }>;
};

const { heading, eyebrow, lead, ctaLabel, ctaHref, items } = Astro.props;
---

<section aria-labelledby="popular-heading" class="keyfo-popular">
  <header class="keyfo-popular-header">
    {eyebrow ? <span class="keyfo-popular-eyebrow">{eyebrow}</span> : null}
    <h2 id="popular-heading" class="keyfo-popular-heading keyfo-brand">{heading}</h2>
    {lead ? <p class="keyfo-popular-lead">{lead}</p> : null}
  </header>

  <ul class="keyfo-popular-grid">
    {items.map((item) => (
      <li class="keyfo-popular-card">
        <div class="keyfo-popular-tile" aria-hidden="true">
          {item.categoryTitle ? <span class="keyfo-popular-badge">{item.categoryTitle}</span> : null}
          <span class="keyfo-popular-tile-emblem">KEYFO</span>
        </div>
        <div class="keyfo-popular-card-body">
          <h3 class="keyfo-popular-name keyfo-brand">{item.name}</h3>
          <span class="keyfo-popular-price keyfo-tabular">{item.priceLabel}</span>
        </div>
      </li>
    ))}
  </ul>

  {ctaLabel && ctaHref ? (
    <div class="keyfo-popular-cta-wrap">
      <a href={ctaHref} class="keyfo-popular-cta">
        <span>{ctaLabel}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  ) : null}
</section>
