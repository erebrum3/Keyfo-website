---
import type { MenuItem } from '../data/menu';

type Props = {
  heading: string;
  eyebrow?: string;
  lead?: string;
  ctaLabel?: string;
  ctaHref?: string;
  items: Array<MenuItem & { priceLabel: string; categoryTitle?: string; description?: string }>;
};

const { heading, eyebrow, lead, ctaLabel, ctaHref, items } = Astro.props;

const slugify = (s: string) =>
  s
    .toLowerCase()
    .normalize('NFKD')
    .replace(/[̀-ͯ]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/(^-|-$)/g, '');
---

<section aria-labelledby="popular-heading" class="keyfo-popular">
  <header class="keyfo-popular-header" data-reveal>
    {eyebrow ? <span class="keyfo-popular-eyebrow">{eyebrow}</span> : null}
    <h2 id="popular-heading" class="keyfo-popular-heading keyfo-brand">{heading}</h2>
    {lead ? <p class="keyfo-popular-lead">{lead}</p> : null}
  </header>

  <ul class="keyfo-popular-grid">
    {items.map((item, idx) => (
      <li class="keyfo-popular-card" data-reveal data-reveal-delay={String(Math.min(idx + 1, 5))}>
        <div class="keyfo-popular-card-image" aria-hidden="true">
          <picture>
            <source
              type="image/avif"
              srcset="/assets/keyfo/popular-hero-320.avif 320w, /assets/keyfo/popular-hero-480.avif 480w, /assets/keyfo/popular-hero-768.avif 768w, /assets/keyfo/popular-hero-960.avif 960w"
              sizes="(max-width: 640px) 45vw, 320px"
            />
            <source
              type="image/webp"
              srcset="/assets/keyfo/popular-hero-320.webp 320w, /assets/keyfo/popular-hero-480.webp 480w, /assets/keyfo/popular-hero-768.webp 768w, /assets/keyfo/popular-hero-960.webp 960w"
              sizes="(max-width: 640px) 45vw, 320px"
            />
            <img
              src="/assets/keyfo/popular-hero-960.jpg"
              srcset="/assets/keyfo/popular-hero-960.jpg 960w"
              sizes="(max-width: 640px) 45vw, 320px"
              width="960"
              height="723"
              alt=""
              loading="lazy"
              decoding="async"
            />
          </picture>
        </div>
        <div class="keyfo-popular-card-body">
          {item.categoryTitle ? (
            <span class="keyfo-popular-badge">
              <span aria-hidden="true" class="keyfo-popular-badge-dot"></span>
              {item.categoryTitle}
            </span>
          ) : null}
          <h3 id={`dish-${slugify(item.name)}`} class="keyfo-popular-name keyfo-brand">{item.name}</h3>
          {item.description ? (
            <p class="keyfo-popular-desc">{item.description}</p>
          ) : null}
          <div class="keyfo-popular-price-row">
            <span aria-hidden="true" class="keyfo-popular-rule"></span>
            <span class="keyfo-popular-price keyfo-brand keyfo-tabular">{item.priceLabel}</span>
          </div>
        </div>
      </li>
    ))}
  </ul>

  {ctaLabel && ctaHref ? (
    <div class="keyfo-popular-cta-wrap">
      <a href={ctaHref} class="keyfo-popular-cta">
        <span>{ctaLabel}</span>
        <span aria-hidden="true">→</span>
      </a>
    </div>
  ) : null}
</section>
