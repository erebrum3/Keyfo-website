# Site verification (optional)
PUBLIC_GOOGLE_SITE_VERIFICATION=
PUBLIC_BING_SITE_VERIFICATION=

# Google Analytics 4 — leave empty to disable tracking
PUBLIC_GA4_MEASUREMENT_ID=G-D99YHX6MTD

# Maintenance overlay (full-screen brand notice over the live site)
# Values: off (default) | maintenance_overlay
# When set to "maintenance_overlay" the site still renders normally (HTTP 200,
# no robots/sitemap/canonical/schema changes), but a full-screen overlay is
# layered on top for visitors. Bypass with ?preview=1 (sets localStorage flag).
PUBLIC_KEYFO_NOTICE_MODE=off
